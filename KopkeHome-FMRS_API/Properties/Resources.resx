  <data name="CustomMembershipHtml" xml:space="preserve">
    <value>&lt;!doctype html&gt;
&lt;html lang="en-US"&gt;

&lt;head&gt;
    &lt;meta content="text/html; charset=utf-8" http-equiv="Content-Type" /&gt;
    &lt;title&gt;Reset Password Email Template&lt;/title&gt;
