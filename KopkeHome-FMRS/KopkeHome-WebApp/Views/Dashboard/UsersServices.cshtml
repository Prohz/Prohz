@model KopkeHome_ModelLayer.ViewModels.DashboardViewModels.UsersServicesModels.UsersServicesViewModel
@{
    ViewData["Title"] = "User Services";
    Layout = "~/Views/Shared/_DashboardInternal.cshtml";
}
<div class="dashboard-main-container">
        

        <div class="dashboard-top-heading dashboard-top-heading-cstm ">
            <h3 class="green-clr mb-5">User Services Details</h3>
            <div class="d-flex align-items-center" >
             <p style="cursor:pointer" class="text-white m-0"><a style="cursor:pointer" onclick="window.history.go(-1); return false;"  class="text-white"><i class="fa fa-long-arrow-left forgot-back-arrow" aria-hidden="true"></i> Go back</a></p>
            <a href="@Url.Action("UsersServicesEdit", "dashboard")" class="button btn green-modal-btn ml-4 edit-button">Edit</a>
    
         </div>
        </div>
<div class="contractor-detail-outerbox">
 <div class="row">
                <div class="col-lg-12 col-md-12 contractor-service-outer-box">
                    <div class="contractor-service-box">
                        <div class="cont-detail-inner-heading">
                            <h3 class="orange-clr">Service Information</h3>
                        </div>
                        <div class="form-contractor-service">
                            <div class="form-group row">
                                <div class="col-sm-12">
                                    <label class="control-label">Service Zip Codes</label>
                                </div>
                                <div class="col-sm-12 contractor-service-zipcodes">
                                   @if(Model.ZipsAndCats.UserMembershipZipcodes!=null)
                                    {
                                        @*foreach(var zips in Model.ZipsAndCats.UserMembershipZipcodes.OrderBy(i=>i.ZipCode.Zipcode))*@
                                       foreach(var zips in Model.ZipsAndCats.UserMembershipZipcodes.OrderBy(i=>i.ZipCodeId))
                                        {
                                            <span>@zips.ZipCodeId</span>

                                        }
                                    }
                                    else
                                    {
                                        <span>No Zip codes found.</span>
                                    }

                                </div>
                            </div>
                            <div class="form-group row">
                                 <div class="col-sm-12">
                                     <label class="control-label service-categories-label">Service Categories</label>
                                 </div>
                                  <div class="col-sm-12 contractor-service-categories-tab">
                                @if(Model.ZipsAndCats.UserMembershipCategories!=null)
                                    {
                                        foreach(var cats in Model.ZipsAndCats.UserMembershipCategories.OrderBy(i=>i.Categories.Name))
                                        {
                                            <span>@cats.Categories.Name</span>

                                        }
                                    }
                                    else
                                    {
                                         <span>No categories found.</span>
                                    }
                                </div>
                            </div>
                          
                        </div>
                    </div>
                </div>
                 </div>
                  </div> </div>