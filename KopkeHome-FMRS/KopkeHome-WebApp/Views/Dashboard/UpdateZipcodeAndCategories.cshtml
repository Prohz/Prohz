    @{
        List<string> LLZIP = new List<string>();
        List<int> LLCAT = new List<int>();
        LLZIP = Model.UserMembershipZipcodes.Select(x => x.ZipCodeId).ToList();
        LLCAT = Model.UserMembershipCategories.Select(x => x.CategoriesId).ToList();

    }

    <script src="~/js/jquery.min.js"></script>
    <script type="text/javascript">
        var tmpzipcodes = [];
        var tmpcategroies = [];
        var allZipocodes = [];
        var allCities = [];

        tmpzipcodes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(LLZIP, Newtonsoft.Json.Formatting.Indented))
            tmpcategroies=@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(LLCAT, Newtonsoft.Json.Formatting.Indented))

                                                                       var ZipcodesLimit = @Model.LimitZipCodes;
        var CategroiesLimit = @Model.LimitCategories;
        $(document).ready(function () {
            RemoveZipcode();
            $("#ddlStateList").change(function () {

                var id = $(this).val();
                $("#ddlCitesList").empty();
                $("#ddlCitesList").append('<option class="text-bg-light">--Select city--</option>')
                $.ajax({
                    url: urlprefix + '/User/GetCitiesList?id=' + id,
                    type: "GET",
                    success: function (result) {
                        $.each(result, function (i, data) {
                            $('#ddlCitesList').append('<option value="' + data.cityName + '" class="text-bg-light">' + data.cityName + '</option>');
                        });
                        
                    }
                });
            });



            $("#ddlCitesList").change(function () {
                var stateId = $("#ddlStateList").val()
                var stateName = $("#ddlStateList option[value='" + stateId + "']").text();
                var id = $(this).val();
                console.log(stateName)
                $("#ListingZip").empty();
                // $("#ddlCitesList").append('<option class="text-bg-light">--Select city--</option>')
                $.ajax({
                    url: urlprefix + '/User/GetzipCodeListbyCityName?CityName=' + id + '&StateName=' + stateName,
                    type: "GET",
                    success: function (result) {
                        $.each(result, function (i, data) {
                            console.log(data);
                            if (tmpzipcodes.indexOf(data.zipcode) > -1) {
                                $('#ListingZip').append('<li><label class="checkbox-inline custome-checkbox-main"><input checked type="checkbox" name="zipcodes" class="form-check-input product-list" data-zipcode=' + data.zipcode + ' id=' + data.zipcode + ' value=' + data.zipcode + ' /><span class="geekmark"></span><label class="mb-0" for="zipcodes">' + data.zipcode + '</label></label></li>');

                            } else {
                                $('#ListingZip').append('<li><label class="checkbox-inline custome-checkbox-main"><input type="checkbox" name="zipcodes" class="form-check-input product-list" data-zipcode=' + data.zipcode + ' id=' + data.zipcode + ' value=' + data.zipcode + ' /><span class="geekmark"></span><label class="mb-0" for="zipcodes">' + data.zipcode + '</label></label></li>');

                            }
                        });
                    }
                });
            });




            $("#SearchInputCategories").on("keyup", function () {
                var value = this.value.toLowerCase().trim();
                $("#ListingCat li").show().filter(function () {
                    return $(this).text().toLowerCase().trim().indexOf(value) == -1;
                }).hide();
            });


            $("#SearchInputZipcode").on("keyup", function () {
                var value = this.value.toLowerCase().trim();
                $("#ListingZip li").show().filter(function () {
                    return $(this).text().toLowerCase().trim().indexOf(value) == -1;
                }).hide();
            });


            $("input[name='category']").change(function () {



                var checked = $(this).val();
                if ($(this).is(':checked')) {

                    if (tmpcategroies.length <= CategroiesLimit - 1) {
                        tmpcategroies.push(checked);

                    }
                    else {
                        this.checked = false;

                        Swal.fire({
                            title: '',
                            iconHtml: ProhzGreyLogo,
                            text: 'You can only select upto ' + CategroiesLimit + ' categories.',

                        });
                    }

                } else {
                    tmpcategroies.splice($.inArray(checked, tmpcategroies), 1);
                }
            });

            $(document).on("change", "input[name='zipcodes']", function () {


                var options_display = $("#options_list");
                var checked = $(this).val();
                if ($(this).is(':checked')) {
                    if (tmpzipcodes.length <= ZipcodesLimit - 1) {
                        tmpzipcodes.push(checked);

                        var zip = $(this).attr("data-zipcode");
                        options_display.append("<li class='' id='Chk_" + checked + "'>" + "<label>" + zip + "</label><button class='RemoveZips' id='" + checked + "' type='button'><i class='fa fa-times'></i></button></li>");
                        //console.log(zip);

                    }
                    else {
                        this.checked = false;

                        Swal.fire({
                            title: '',
                            iconHtml: ProhzGreyLogo,
                            text: 'You can only select upto ' + ZipcodesLimit + ' Zip codes.',

                        });
                    }

                }
                else {

                    tmpzipcodes.splice($.inArray(checked, tmpzipcodes), 1);


                    $('#Chk_' + checked).remove();


                }
            });

            $('#button1').on('click', function () {
                ZipcodesAndCategories();
            });

        });



        //function ZipcodesAndCategories()
        //  {
        //      console.log("HIT 2");
