        //         }


        //      }


        //      });
        //      }





        ////  }

        function ZipcodesAndCategories() {
            //console.log("HIT 1");
            var ischecked = ValidateCheckbox();
            if (ischecked) {
                $.ajax({
                    type: 'Post',
                    url: urlprefix + '/Membership/selectzipcodesandcategories',
                    data: { Zipcodes: tmpzipcodes, categories: tmpcategroies, PlanId: @Model.PlanId },
                    success: function (res) {

                        if (res == 1) {
                            //alert("Entered");
                            window.location = urlprefix + "/dashboard/index";
                        }
                        //alert("failed");


                    }


                });
            }





        }


        var getChecked = function () {
            var n = $("input[name='zipcodes']");
            $("input[name='zipcodes']").each(function (index, obj) {

            });
            var options_display = $("#options_list")
            //console.log(n)
            if (n.length != 0) {
                $.each(n, function (index, value) {
                    options_display.append("<li>" + value.defaultValue + "</li>")
                });
            }
            else {
                options_display.html("<h3 class'text-center'>No Options</h3>")
            }
        };

        function RemoveZipcode() {
            $(document).on('click', '.RemoveZips', function () {
                debugger
                var id = $(this).attr("id");
                $('body #Chk_' + id).remove();
                var checkid = $('#' + id);
                checkid.prop("checked", false);
                //$('#'+id).attr('checked', false);
                tmpzipcodes.splice($.inArray(id, tmpzipcodes), 1);

            });
        }

        function ValidateCheckbox() {
            var IsPassed = true;
            if (!$('input:checkbox[name="zipcodes"]').is(':checked')) {
                if (typeof tmpzipcodes[0] === 'undefined') {
                    Swal.fire({
                        icon: 'info',
                        title: 'Please select zip code.',

                    })
                    Swal.fire({
                        title: '',
                        iconHtml: ProhzGreyLogo,
                        text: 'Please select zip code.',

                    });
                    IsPassed = false;
                }




            }
            if (!$('input:checkbox[name="category"]').is(':checked')) {
                if (typeof tmpcategroies[0] === 'undefined') {
                    Swal.fire({
                        title: '',
                        iconHtml: ProhzGreyLogo,
                        text: 'Please select category.',

                    });

                    IsPassed = false;
                }
            }


            return IsPassed;


        }




    </script>
</body>
</html>