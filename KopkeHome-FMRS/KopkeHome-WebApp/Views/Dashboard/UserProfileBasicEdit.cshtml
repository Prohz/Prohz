        <div>
            <p class="text-white m-0"><a href="@Url.Action("UserProfileDetails", "dashboard")" class="text-white"><i class="fa fa-long-arrow-left forgot-back-arrow" aria-hidden="true"></i> @Localizer["Go back"]</a></p>
        </div>
    </div>


    <div class="dashboard-main-inner-content User-Profile-BI-inner-content">
