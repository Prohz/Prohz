<div class="logo-loader " ID="CSTMLOADER" style="display:none">
    <div class="logo-loader-pulse pulse" id="Idloader"><img src="~/images/Kopke-brand-logo.png" /></div>
</div>





<div class="dashboard-main-container">

    <div class="dashboard-top-heading dashboard-top-heading-cstm ">
        <h3 class="green-clr mb-5">@Localizer["Membership Benefits Plan For"] @membertype</h3>
        <div class="d-flex align-items-center">
            <p class="text-white m-0"><a href="@Url.Action("index", "dashboard")" class="text-white"><i class="fa fa-long-arrow-left forgot-back-arrow" aria-hidden="true"></i> @Localizer["Go back"]</a></p>


        </div>
    </div>

    <div class="text-right">
        @{

            if (Model.SubscriptionsStripeData.StripeStatus.Contains("Cancelled"))
            {
                <p class="text-warning">@Localizer["Your current plan is cancelled but you can use the application until"] @Model.SubscriptionsStripeData.PeriodEndDate </p>
                @if (Model.CustomPlan == null)
                {
                    <span class="" style="color:#fff">@Localizer["Want Customized Plan ?"] </span> <button type="button" class="button btn btn-cstm-membership" data-toggle="modal" data-target="#exampleModal">@Localizer["Click here"]</button>
                }
            }
            else
            {
                <p class="text-success">@Localizer["Subscription expires on"] @Model.SubscriptionsStripeData.PeriodEndDate @Localizer["(AutoRenewable)"]</p>
                @if (Model.CustomPlan == null)
                {
                }  <button id="@Model.SubscriptionsStripeData.StripeSubscriptionId" data-EndDate="@Model.SubscriptionsStripeData.PeriodEndDate" onclick="CancelSubscription(this);" type="button" class="button btn red-modal-btn">@Localizer["Cancel Subscription"]  <i class="fa-light fa-xmark"></i></button>

            }
            //if (Model.SubscriptionsStripeData.StripeStatus.Contains("complete"))
            //{
            //     <p class="text-warning">@Localizer["Plan is AutoRenewable"]</p>
            //}
        }
    </div>
