@{
    ViewData["Title"] = "Forgot Password | "; 
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@inject IViewLocalizer Localizer


<div class="registration-container-login">



     
  
  <div class="modal p-0 fade email-sent-success-modal"  data-keyboard="false" data-backdrop="static" id="PwdResetLinkModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
      

        <div class="modal-body">
          <div class="text-center email-sent-success-main-heading">         
               <img width="175px" src="~/images/success-gif1.gif" />
               @*<img width="175px" src="~/images/success-gif.gif" />*@
          
              <h3 class="text-white">@Localizer["Password reset link sent."]</h3>
               <p>@Localizer["Your password reset link has been sent successfully. Please check your email to reset your password."]</p>        
          </div>
          
         <div class="verify-email text-center mb-2">
          <a class="btn green-email-verify-btn" href="@Url.Action("signin", "user")"> 
           OK</a>
       </div>
        
     
        
        </div>
        
      </div>
    </div>
  </div>
  










   <div class="registration-container-form">

      
    <div class="forgot-pwd-page">
            <div class="kopkehome-login-logo-heading text-center">
                <img src="../images/Kopke-brand-logo.png" width="110" />
            </div>
             <div class="forgot-pwd-page-content">
                    <form onsubmit="return ForgotPasswordLinkSend();">
                      <div class="forgot-pwd-main-headin">
                            <h3 class="green-clr">@Localizer["Forgot Password"]</h3>
                            <p class="text-white">@Localizer["Please enter your email below to receive your password reset link."]</p>
                        </div>
                         <div class="row">
                         
                               <div class="form-group col-md-12">
                                <div class=" rgstr-input-form-box mb-1">
                                <label  for="Email">Email</label>
                                <input id="EmailForgotPassword" type="text" name="Email" placeholder="Email" class="form-control input-sm" />
                                 <span id="EmailForgotPasswordlbl" class="text-danger"></span>  
                            </div>
                              </div>
                        
                         
                          
                          
                               
                             <div class="col-md-12 text-center login-cstm-button">
                                <button type="submit"  class="btn payment-btn cstm-green-btn w-100">@Localizer["Send"]</button>
                            </div>
                
                            <div class=" col-md-12 member-login-link text-center d-flex align-items-center justify-content-center">
                                <p class="text-white m-0"><i class="fa fa-long-arrow-left forgot-back-arrow" aria-hidden="true"></i> @Localizer["Go back to"] <a href="@Url.Action("signin", "user")"  class="green-clr green-clr-link">@Localizer["Login"]</a></p>
                            </div>
                         </div>    
                 </form>

             </div>
             </div>
        </div>
</div>


