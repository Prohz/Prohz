    <script>



        $(document).ready(function () {


            $(".modal-cstm-close").click(function () {
                $("#contactorModal").modal('hide');
            });

        });


        $(window).on('load', function () {

            var checkval = $('#home_Owner').prop('checked');
            if (checkval == true) {
                $("#Contractor").removeClass('active');
                $("#Home-Owner").addClass('active')
                $('#RoleId').val("4");

            }
        });
    </script>

