<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>@Localizer["Register Page"]</title>
    <meta name="description" content="">
    <meta name="author" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    @*
    <link href='https://fonts.googleapis.com/css?family=Poppins' rel='stylesheet'>*@

    @*<link rel="stylesheet" href="~/css/master.css">*@


    @*<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css">*@
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/master.css" />
    <link rel="stylesheet" href="~/css/responsive.css">
</head>

<body>

    <div class="mm">
        <div class="modal1">

            <div class="logo-loader-pulse pulse" id="Idloader">
                <a href="@Url.Action("index","home")">
                    <img id="Logoimgurl" src="~/images/Kopke-brand-logo.png" />
                </a>
            </div>
        </div>
    </div>

    <div class="registration-container black-bg">
        <!--  Email verfication Modal -->
        <div class="modal p-0 fade contactorModal-email-varification" data-keyboard="false" data-backdrop="static"
             id="contactorModal">`
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title">@Localizer["Email Verification"]</h4>
                        <button type="button" class="close modal-cstm-close" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <div class="text-center email-varification-main-heading">
                            <h3 class="text-white">@Localizer["Enter verification code"]</h3>
                            <p>
                                @Localizer["Please check your email"] (<span id="VerificationEmail1"></span>)
                                @Localizer["and enter the verification code below to verify your email address."]
                            </p>
                        </div>
                        <form id="form" asp-action="VerifyOTP" onsubmit="return submitVerifyOtp(this);">
                            <div class="userInput">
                                <input type="number" maxLength="1" id="first" size="1" min="0" max="9"
                                       pattern="[0-9]{1}" onKeyPress="if(this.value.length==1) return false;" />
                                <input class="not-first" type="number" id="second" maxLength="1" size="1" min="0"
                                       max="9" pattern="[0-9]{1}" onKeyPress="if(this.value.length==1) return false;" />
                                <input class="not-first" type="number" id="third" maxLength="1" size="1" min="0" max="9"
                                       pattern="[0-9]{1}" onKeyPress="if(this.value.length==1) return false;" />
                                <input class="not-first" type="number" id="fourth" maxLength="1" size="1" min="0"
                                       max="9" pattern="[0-9]{1}" onKeyPress="if(this.value.length==1) return false;" />
                                <input class="not-first" type="number" id="fifth" maxLength="1" size="1" min="0" max="9"
                                       pattern="[0-9]{1}" onKeyPress="if(this.value.length==1) return false;" />
                                <input class="not-first" type="number" id="sixth" maxLength="1" size="1" min="0" max="9"
                                       pattern="[0-9]{1}" onKeyPress="if(this.value.length==1) return false;" />
                                <input type="hidden" value="" id="Email1" />

                                <div class="cstm-span-error-msg">
                                    <span id="spnMessage"></span>
                                </div>
                            </div>

                            <div class="verify-email text-center mb-2">
                                <button type="submit" class="btn green-email-verify-btn">@Localizer["Verify"]</button>
                            </div>
                        </form>
                        @*<div class="text-center resend-email-otp">
                        <p class="mb-0"> Didn't receive the verification code?</p>
                        <a href="#" class="orange-clr">Resend again</a>
                        </div>*@
                    </div>
                </div>
            </div>
        </div>
        <!-- Email verfication Modal end -->


        <div class="registration-container-branding d-flex justify-content-between align-items-center">
            <a href="@Url.Action("index","Home")">
                <div class="kopkehome-logo">
                    <img src="~/images/Kopke-brand-logo.png" width="140" />
                </div>
            </a>
            @await Html.PartialAsync("SelectCulture")
            <div class="rgstr-box-heading text-center">
                <h2 class="orange-clr">@Localizer["Your networking starts here"]</h2>
                <p class="text-white m-0">@Localizer["Sign up is quick and easy."]</p>
            </div>
            <div class="member-login-link">
                <p class="text-white m-0">@Localizer["Already A Member?"]</p> <a href="@Url.Action("signin", "user")"
                                                                                 class=" green-clr-top-login-link ">@Localizer["Login"]</a>
            </div>
            @* <div class="member-login-link">
            <p class="text-white m-0">Already a member? <a href="http://dbprod/KopkeHome-FMRS-QA/User/SignIn" class="
            green-clr-top-login-link ">Login</a></p>
            </div>*@
        </div>

        <div class="container">
            <div class="notice-body">
                <div class="notice">
                    <h3 class="green-clr">Please Note</h3>
                    <p class="text-white m-0">A one-time non-refundable fee of $99 will be charged for business verification to ensure the authenticity and security of your business on our platform.</p>
                </div>
            </div>
        </div>



        <div class="container">
            <div class="notice">
                <div class="rgstr-main-heading justify-content-between align-items-center margin">
                    <h3 class="green-clr">@Localizer["Are you a Contractor, or Subcontractor?"]</h3>
                    <p class="text-white m-0">@Localizer["Select only one."]</p>
                </div>

            </div>

        </div>


        <div class="registration-container-form">

            <div role="tablist" style="display: flex;">

                <div style="margin: 5px; border-radius: 10px; flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; background-color: #454A57;">
                    <input style="margin: 15px;" id="general_Contractor" name="intervaltype" type="radio">
                    <label style="margin-top: 5px; color: white; font-size: 1.75rem;">Contractor</label>
                </div>

                <div style="margin: 5px; border-radius: 10px; flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; background-color: #454A57;">
                    <input style="margin: 15px;" id="Sub_Contractor" name="intervaltype" type="radio">
                    <label style="margin-top: 5px; color: white; font-size: 1.75rem;">Subcontractor</label>
                </div>

            </div>
            




            <div class="rgstr-main-heading mb-3">
                <h3 class="green-clr">@Localizer["Basic Information"]</h3>
            </div>
            <!-- The contractor Modal end -->
            <div class="tab-content" id="tabs">

                <div id="Contractor" class="tab-pane active">
                    @*<form data-ajax="true" asp-action="SignUp" data-ajax-complete="succesmodal"
                    class="sign-from-section p-md-3 p-1" asp-controller="User">*@
                    <partial name="_ContractorBasicInfo" />
                </div>

                <div id="Home-Owner" class="tab-pane ">
                    @* @Html.RenderPartial("_HomeOwnerBasicInfo");*@
                    <partial name="_HomeOwnerBasicInfo.cshtml" />
                </div>
            </div>
        </div>
    </div>

