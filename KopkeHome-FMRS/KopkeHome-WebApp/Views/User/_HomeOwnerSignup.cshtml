@model KopkeHome_ModelLayer.ViewModels.HomeOwnerViewModel;


 @*<form id="homeownerform" class="sign-from-section p-md-3 p-1" onsubmit="return RegstrHomeOwner(this);">*@
               <form asp-action="HomeOwnerSignUp" data-ajax-complete="succesmodal" asp-controller="User" method="post" { enctype="multipart/form-data" } class="sign-from-section p-md-3 p-1" onsubmit="return RegstrHomeOwner(this);">        
                        <div class="row">
                            <input type="hidden" asp-for="RoleId" value="4" />
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label class="required-labl" for="FirstName">First Name</label>
                                    <input type="text" asp-for="FirstName" placeholder="First Name" class="form-control" />
                                    <span asp-validation-for="HomeOwnerViewModel.FirstName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label class="required-labl" for="LastName">Last Name</label>
                                    <input type="text" name="LastName" placeholder="Last Name" class="form-control" />
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label class="required-labl" for="Email">Email Address</label>
                                    <input type="text" name="Email" placeholder="Email Address" class="form-control input-sm" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label class="required-labl" for="Password">Password</label>
                                    <input type="password" name="Password" placeholder="Enter Password" class="form-control input-sm" />
                                     <i class="toggle-password fa fa-fw fa-eye-slash"></i>
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label class="required-labl" for="ConfirmPassword">Confirm Password</label>
                                    <input type="password" name="ConfirmPassword" placeholder="Enter Confirm Password" class="form-control input-sm" />
                                     <i class="toggle-password fa fa-fw fa-eye-slash"></i>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>
                             <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label for="BusinessAddress">Business Address</label>
                                    <input type="text" asp-for="BusinessAddress" name="BusinessAddress" placeholder="Business Address" class="form-control input-sm" />
                                    <span asp-validation-for="BusinessAddress" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label for="City">City</label>
                                    <input type="text" name="City" placeholder="City" class="form-control" />
                                    <span asp-validation-for="City" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label for=" State">State</label>
                                    <input type="text" asp-for="State" placeholder="State" name="State" class="form-control input-sm" />
                                    <span asp-validation-for="State" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label for="ZipCode">Zip Code</label>
                                    <input type="text" name="ZipCode" placeholder="Enter Zip Code" class="form-control input-sm" />
                                    <span asp-validation-for="ZipCode" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label for="PhoneNumberOffice">Phone number (Home)</label>
                                    <input type="text" name="PhoneNumberOffice" placeholder="Phone number (Office)" class="form-control input-sm" />
                                    <span asp-validation-for="PhoneNumberOffice" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group col-md-4">
                                <div class=" rgstr-input-form-box">
                                    <label for="PhoneNumber">Phone Number (Mobile)</label>
                                    <input type="text" name="PhoneNumber" placeholder="Phone Number (Mobile)" class="form-control input-sm" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                            @*<div class="col-md-12 text-right">

                                <button type="button" class="btn cstm-green-btn" data-toggle="modal" data-target="#HomeownercontactorModal">Next</button>
                                </div>*@
                            <div class="col-md-12 text-right">
                                @*<input type="submit" value="Next" class="btn cstm-green-btn"/>*@
                                <button type="submit" style="background-color:#ADD136" class="btn cstm-green-btn">Next</button>
                            </div>
                        </div>
                    </form>