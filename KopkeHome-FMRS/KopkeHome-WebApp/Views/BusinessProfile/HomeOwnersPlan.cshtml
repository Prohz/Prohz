@model KopkeHome_ModelLayer.DataModel.Dashboard
@{
    Layout = null;
}
<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css">



    @*
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />*@

    <link rel="stylesheet" href="~/KopkeHome_Web.styles.css" asp-append-version="true" />

    @*
    <link rel="stylesheet" type="text/css" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.6.3/css/font-awesome.min.css">*@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/master.css" asp-append-version="true" />
</head>
<body>

    <div class="registration-container black-bg">



        <div class="registration-container-branding d-flex justify-content-between align-items-center">
            <div class="kopkehome-logo">
                <img src="~/images/Kopke-brand-logo.png" width="140" />
            </div>

            <div class="rgstr-box-heading text-center">
                <h2 class="orange-clr">Home Owner Membership Benefits</h2>
                <p class="text-white m-0">Please choose the best membership benefits for you.</p>
            </div>

            <div class="member-login-link">
                <p class="text-white m-0">Already a member? <a href="User/SignIn" class=" green-clr-top-login-link ">Login</a></p>
            </div>
        </div>



        <div class="registration-container-form">
            <div class="tab-content">





                <div id="Home-owner" class="contractor-business-prof-form">
                    <div class="Membership-benefits-outer-box">
                        <div class="table-responsive benefit-table">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th class="d-flex justify-content-center align-items-center">
                                            <h2>Membership Benefits</h2>
                                        </th>
                                        <th>
                                            <span class="membership-title membership-title-1">Free</span>
                                            <h2>$0.0</h2>
                                        </th>
                                        <th>
                                            <span class="membership-title membership-title-2">Silver</span>
                                            <h2>$29.99/Year</h2>
                                        </th>
                                        <th>
                                            <span class="membership-title membership-title-3">Gold</span>
                                            <h2>$59.99/Year</h2>
                                        </th>
                                        @*
                                        <th>
                                            <span class="membership-title membership-title-4">Unlimited</span>
                                            <h2>$89.99/Year</h2>
                                        </th>*@
                                    </tr>
                                </thead>



                                <tbody>


                                    <tr>
                                        <th>Website</th>
                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>
                                    </tr>
                                    <tr>
                                        <th>Mobile App</th>
                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>

                                    </tr>
                                    <!-- another 6 -->
                                    <tr>
                                        <th>Other Benefits 1</th>

                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-times fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>

                                    </tr>
                                    <tr>
                                        <th>Other Benefits 2</th>

                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-times fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>

                                    </tr>
                                    <tr>
                                        <th>Other Benefits 3</th>

                                        <td><i class="fa fa-check fa-2x"></i></td>
                                        <td><i class="fa fa-times fa-2x"></i></td>
                                        <td><i class="fa fa-check fa-2x"></i></td>

                                    </tr>

                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th>&nbsp;</th>
                                        <td><a href="http://dbprod/KopkeHome-FMRS-QA/user/signin" class="text-decoration-none membership-title-1">BUY NOW</a></td>
                                        <td><a href="#" class=" text-decoration-none membership-title-2">BUY NOW</a></td>
                                        <td><a href="#" class="text-decoration-none membership-title-3">BUY NOW</a></td>

                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>




            </div>
        </div>
    </div>






















    @*  <header>
        <h1>Wellcome to the dashboard</h1>
        <p>Category</p>
        <p>Sub Category</p>
    </header>*@



    <!-- jQuery library -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"></script>

    <!-- Popper JS -->
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>

    <!-- Latest compiled JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="./js/custom.js"></script>
</body>
</html>

