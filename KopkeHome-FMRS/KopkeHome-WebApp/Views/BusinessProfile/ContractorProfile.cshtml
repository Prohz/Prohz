@model KopkeHome_ModelLayer.ViewModels.BusinessProfileViewModel;
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Contractor Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@*
@if(ViewBag.data != null)
{

} *@

<div class="registration-container black-bg">



    <div class="registration-container-branding d-flex justify-content-between align-items-center">
        <div class="kopkehome-logo">
            <a href="@Url.Action("SignIn","user")">
                <img src="~/images/Kopke-brand-logo.png" width="140" />
            </a>
        </div>
        @await Html.PartialAsync("SelectCulture")
        <div class="rgstr-box-heading text-center">
            <h2 class="orange-clr">@Localizer["Business Profile Registration"]</h2>
            <p class="text-white m-0">@Localizer["Please fill the form below to create Business profile."]</p>
        </div>
        <div class="">
            @{
                if (Model.LoggedInUser != null)
                {
                    <a class="nav-link text-dark dropdown-toggle d-flex align-items-center" href="#" id="navbardrop" data-toggle="dropdown">
                        @if (!string.IsNullOrEmpty(Model.LoggedInUser.ProfilePicture))
                        {
                            <img alt="logo" style="margin-right:11px; class="IconBorder" src="~/Uploads/@Model.LoggedInUser.ProfilePicture" width="38" />

                            <span class="text-white">@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName </span>
                        }
                        else
                        {
                            <img alt="logo" style="margin-right:11px;" src="~/images/DefaultProfile.png" class="IconBorder" width="38" />

                            <span class="text-white">@Model.LoggedInUser.FirstName @Model.LoggedInUser.LastName</span>
                        }

                    </a>
                }


            }

        </div>

    </div>



    <div class="registration-container-form">
        <div class="tab-content">
            <div id="Contractor" class="contractor-business-prof-form">
                <div class="rgstr-main-heading">
                    <h3 class="green-clr">@Localizer["Business Profile Registration"]</h3>
                </div>

                <form name="ContractorBusinessProfile" asp-action="BusinessProfileSave" enctype="multipart/form-data" method="post" onsubmit="return ContractorBusinessProfileValidate(this);" asp-controller="BusinessProfile">
                    @* <input asp-for="LoggedInUser" type="hidden"/>*@

                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="form-group col-md-6 col-lg-4  ">
