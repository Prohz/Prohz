                                    <option value="Cabinet - Installer">@Localizer["Cabinet - Installer"]</option>
                                    <option value="Cabinet Refacing Company">@Localizer["Cabinet Refacing Company"]</option>
                                    <option value="Carpenters - Rough">@Localizer["Carpenters - Rough"]</option>
