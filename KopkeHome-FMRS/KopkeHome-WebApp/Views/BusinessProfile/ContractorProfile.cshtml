                                    <option value="Window Installers">@Localizer["Window Installers"]</option>
                                </select>

                            </div>
                        </div>
                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="YearsInBusiness"> @Localizer["How many years have you been in business?"]</label>
                                <input type="number" name="YearsInBusiness" placeholder="@Localizer["Enter business years..."]" class="form-control" />
                                <span asp-validation-for="YearsInBusiness" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="IsCompanyWebsite">@Localizer["Do you have a company website?"]</label>
                                <div class="d-flex justify-content-between w-50 question-text-radio-btn">
                                    <div class="custom-radio ">
                                        <input name="IsCompanyWebsite" id="credit1" class="custom-control-input" type="radio" value="true" />
                                        <label class="custom-control-label" for="credit1">@Localizer["Yes"] </label>
                                        <span asp-for="IsCompanyWebsite" class="text-danger"></span>
                                    </div>
                                    <div class="custom-radio">
                                        <input name="IsCompanyWebsite" id="credit2" class="custom-control-input" type="radio" value="false" />
                                        <label class="custom-control-label" for="credit2">@Localizer["No"]</label>
                                        <span asp-for="IsCompanyWebsite" class="text-danger"></span>
                                    </div>
                                </div>

                                <span name="IsCompanyWebsite1" class="text-danger " data-valmsg-for="IsCompanyWebsite"></span>
                            </div>
                        </div>
                        <div class="form-group col-md-6 col-lg-4  " id="web3" style="display:none">
                            <div class=" rgstr-input-form-box">
                                <label for="CompanyWebsiteURL">@Localizer["Website"]</label>
                                <div class="input-group mb-3">


                                    <input type="text" name="CompanyWebsiteURL" aria-describedby="basic-addon3" placeholder="example.com" class="form-control" />
                                </div>
                                <span asp-validation-for="CompanyWebsiteURL" class="text-danger"></span>
                            </div>
                        </div>


                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="IsFacebookPage">@Localizer["Do you have Facebook page?"]</label>
                                <div class="d-flex justify-content-between w-50 question-text-radio-btn">
                                    <div class="custom-radio ">
                                        <input name="IsFacebookPage" id="credit3" class="custom-control-input" type="radio" value="true" />
                                        <label class="custom-control-label" for="credit3">@Localizer["Yes"] </label>
                                        <span asp-for="IsFacebookPage" class="text-danger"></span>
                                    </div>
                                    <div class="custom-radio">
                                        <input name="IsFacebookPage" id="credit4" class="custom-control-input" type="radio" value="false" />
                                        <label class="custom-control-label" for="credit4">@Localizer["No"]</label>
                                        <span asp-for="IsFacebookPage" class="text-danger"></span>
                                    </div>
                                </div>

                                <span asp-validation-for="CompanyWebsiteURL" class="text-danger"></span>
                            </div>
                        </div>







                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="NumberOfEmployees">@Localizer["How many employees do you have?"]</label>
                                <input type="number" name="NumberOfEmployees" placeholder="Enter number of employees" class="form-control" />
                                <span asp-validation-for="NumberOfEmployees" class="text-danger"></span>
                            </div>
                        </div>

















                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="IsBusinessOrTradeLicense">@Localizer["Do you have a business or trade license(s)?"]</label>
                                <div class="d-flex justify-content-between w-50 question-text-radio-btn">
                                    <div class="custom-radio ">
                                        <input name="IsBusinessOrTradeLicense" id="credit13" class="custom-control-input" type="radio" value="true" />
                                        <label class="custom-control-label" for="credit13">@Localizer["Yes"] </label>
                                        <span asp-for="IsBusinessOrTradeLicense" class="text-danger"></span>
                                    </div>
                                    <div class="custom-radio">
                                        <input name="IsBusinessOrTradeLicense" id="credit14" class="custom-control-input" type="radio" value="false" />
                                        <label class="custom-control-label" for="credit14">No</label>
                                        <span asp-for="IsBusinessOrTradeLicense" class="text-danger"></span>
                                    </div>
                                </div>

                                <span name="IsBusinessOrTradeLicense1" class="text-danger field-validation-valid" data-valmsg-for="IsBusinessOrTradeLicense"></span>
                            </div>
                        </div>






                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="IsLiabilityInsurance">@Localizer["Do you have Liability Insurance?"]</label>
                                <div class="d-flex justify-content-between w-50 question-text-radio-btn">
                                    <div class="custom-radio ">
                                        <input name="IsLiabilityInsurance" id="credit15" class="custom-control-input" type="radio" value="true" />
                                        <label class="custom-control-label" for="credit15">@Localizer["Yes"] </label>
                                        <span asp-for="IsLiabilityInsurance" class="text-danger"></span>
                                    </div>
                                    <div class="custom-radio">
                                        <input name="IsLiabilityInsurance" id="credit16" class="custom-control-input" type="radio" value="false" />
                                        <label class="custom-control-label" for="credit16">No</label>
                                        <span asp-for="IsLiabilityInsurance" class="text-danger"></span>
                                    </div>
                                </div>

                                <span name="IsLiabilityInsurance1" class="text-danger field-validation-valid" data-valmsg-for="IsLiabilityInsurance"></span>
                            </div>
                        </div>






                        <div class="form-group col-md-6 col-lg-4  ">
                            <div class=" rgstr-input-form-box">
                                <label for="IsWorkmanCompensationInsurance">@Localizer["Do you have Workman’s Compensation Insurance?"]</label>
                                <div class="d-flex justify-content-between w-50 question-text-radio-btn">
                                    <div class="custom-radio ">
                                        <input name="IsWorkmanCompensationInsurance" id="credit17" class="custom-control-input" type="radio" value="true" />
                                        <label class="custom-control-label" for="credit17">@Localizer["Yes"] </label>
                                        <span asp-for="IsWorkmanCompensationInsurance" class="text-danger"></span>
                                    </div>
                                    <div class="custom-radio">
                                        <input name="IsWorkmanCompensationInsurance" id="credit18" class="custom-control-input" type="radio" value="false" />
                                        <label class="custom-control-label" for="credit18">No</label>
                                        <span asp-for="IsWorkmanCompensationInsurance" class="text-danger"></span>
                                    </div>
                                </div>

                                <span name="IsWorkmanCompensationInsurance1" class="text-danger field-validation-valid" data-valmsg-for="IsWorkmanCompensationInsurance"></span>
                            </div>
                        </div>






















                        <div class="col-md-12 text-right">
                            <button type="submit" class="btn cstm-green-btn">@Localizer["Next"] <i class="fa fa-long-arrow-right"></i></button>
                        </div>



                    </div>



                </form>
            </div>
        </div>
    </div>
</div>


