                                    <option value="Concrete - Driveway/Sidewalk">@Localizer["Concrete - Driveway/Sidewalk"]</option>
                                    <option value="Concrete - Stamped/Stained/Sealed">@Localizer["Concrete - Stamped/Stained/Sealed"]</option>
                                    <option value="Countertops - Corian/Solid Surface">@Localizer["Countertops - Corian/Solid Surface"]</option>
                                    <option value="Countertops - Granite/Quartz">@Localizer["Countertops - Granite/Quartz"]</option>
                                    <option value="Doors - Interior/Exterior">@Localizer["Doors - Interior/Exterior"]</option>
                                    <option value="Drywall Companies">@Localizer["Drywall Companies"]</option>
                                    <option value="Dumpster Rental Companies">@Localizer["Dumpster Rental Companies"]</option>
                                    <option value="Electricians">@Localizer["Electricians"]</option>
                                    <option value="Environmental Companies">@Localizer["Environmental Companies"]</option>
                                    <option value="Excavation Companies">@Localizer["Excavation Companies"]</option>
                                    <option value="Fence Companies">@Localizer["Fence Companies"]</option>
                                    <option value="Finish Carpenter">@Localizer["Finish Carpenter"]</option>
                                    <option value="Fireplace Companies">@Localizer["Fireplace Companies"]</option>
                                    <option value="Fireplace Installer">@Localizer["Fireplace Installer"]</option>
                                    <option value="Flooring Companies">@Localizer["Flooring Companies"]</option>
