                                    <option value="Flooring Installer and refinisher – Hard Wood">@Localizer["Flooring Installer and refinisher – Hard Wood"]</option>
                                    <option value="Foundation Companies">@Localizer["Foundation Companies"]</option>
                                    <option value="Furnace and Air Conditioning Companies">@Localizer["Furnace and Air Conditioning Companies"]</option>
                                    <option value="Garage Door Companies">@Localizer["Garage Door Companies"]</option>
                                    <option value="Garage Door Installers">@Localizer["Garage Door Installers"]</option>
                                    <option value="General Contractors">@Localizer["General Contractors"]</option>
                                    <option value="General Labor Services">@Localizer["General Labor Services"]</option>
                                    <option value="Gravel Driveway Companies">@Localizer["Gravel Driveway Companies"]</option>
                                    <option value="Gutter Companies">@Localizer["Gutter Companies"]</option>
                                    <option value="Handyman Services">@Localizer["Handyman Services"]</option>
                                    <option value="HVAC Companies">@Localizer["HVAC Companies"]</option>
                                    <option value="Insulation Companies">@Localizer["Insulation Companies"]</option>
                                    <option value="Insulation installer – Blown-in">@Localizer["Insulation installer – Blown-in"]</option>
                                    <option value="Insulation Installer - Rolled">@Localizer["Insulation Installer - Rolled"]</option>
                                    <option value="Insulation Installer - Spray Foam">@Localizer["Insulation Installer - Spray Foam"]</option>
                                    <option value="Interior Design">@Localizer["Interior Design"]</option>
                                    <option value="Kitchen Remodeling Companies">@Localizer["Kitchen Remodeling Companies"]</option>
                                    <option value="Kitchen/Bath Designers">@Localizer["Kitchen/Bath Designers"]</option>
                                    <option value="Mold Testing/Remediation Companies">@Localizer["Mold Testing/Remediation Companies"]</option>
                                    <option value="Painting - Exterior">@Localizer["Painting - Exterior"]</option>
                                    <option value="Painting - Interior">@Localizer["Painting - Interior"]</option>
                                    <option value="Patio Doors">@Localizer["Patio Doors"]</option>
