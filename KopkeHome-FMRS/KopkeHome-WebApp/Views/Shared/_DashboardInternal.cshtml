@model KopkeHome_ModelLayer.ViewModels.DashboardViewModels.BaseViewModel
@Html.AntiForgeryToken()
@inject IViewLocalizer Localizer
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Prohz</title>

     <link rel="icon" href="~/favicon.ico" type="image/x-icon">
    

     <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="~/css/datatables.min.css" />
    <link  rel="stylesheet" href="~/css/responsive.bootstrap.min.css" /> 
    <link rel="stylesheet" href="~/css/jquery.dataTables.min.css"  />
    
      <link rel="stylesheet" href="~/css/master.css" asp-append-version="true" />
      <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
       <link rel="stylesheet" href="//code.jquery.com/ui/1.13.1/themes/base/jquery-ui.css" asp-append-version="true">



      </head>
<body>
    <nav class="navbar navbar-expand-xl  fixed-top shadow" id="top-nav-header">
        
        <a class="navbar-brand " href="@Url.Action("index", "dashboard")">
            <img src="~/images/Kopke-brand-logo.png" alt="logo" class="ml-1 Logoimgurl">
        </a>

        <a class="navbar-brand btn btn-secondary" href="@Url.Action("index", "dashboard")">
            <p class="mb-0">Search for members</p>
        </a>

        <div class="d-flex align-item-center" >
           
             @await Html.PartialAsync("SelectCulture")
             @*<select class="LangDropDown" name="Lang">
  <option value="Eng">English</option>
  <option value="Spanish">Spanish</option>
  
</select>*@
            <button id="searchbutton" class="navbar-toggler  dashboard-navbar-toggler-btn" type="button" data-toggle="collapse" data-target="#collapsibleNavbar">
            @*<i class="fa fa-ellipsis-v fa-1x" aria-hidden="true"></i>*@
             <i class="fa fa-search fa-1x" aria-hidden="true"></i>
        </button>





        <div class="collapsibleNavbarMobile">




        <ul class="mb-0 pl-0 mobile-user"  style="list-style: none;" >
        <li class="nav-item dropdown user-profile-imge mb-0">
                    <a class="nav-link text-dark dropdown-toggle d-flex align-items-center" href="#" id="navbardrop" data-toggle="dropdown">
                        @if(!string.IsNullOrEmpty(Model.LoggedInUser.ProfilePicture))
                        {
                             <img alt="logo"  class="IconBorder" src="../Uploads/@Model.LoggedInUser.ProfilePicture" width="38" /><span class="text-white">@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName </span>  
                        }
                        else
                        {
                             <img alt="logo" src="../images/DefaultProfile.png" class="IconBorder" width="38" /><span class="text-white">@Model.LoggedInUser.FirstName @Model.LoggedInUser.LastName</span>
                        }

                    </a>
                     <div class="dropdown-menu ">
                        <a class="dropdown-item" href="@Url.Action("UserProfileDetails", "dashboard")"  > <i class="fa fa-user" aria-hidden="true"></i>@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName</a>
                        
                        @if (Model.LoggedInUser.RoleId!=null)
                        {
                            if(Model.LoggedInUser.RoleId!=4)
                            {
                             <a class="dropdown-item" href="@Url.Action("businessprofiledetail", "dashboard")"><i class="fa fa-pencil" aria-hidden="true"></i>@Localizer["View Business Profile"]</a>
@*                     <a class="dropdown-item" href="@Url.Action("UsersServices", "dashboard")"><i class="fa fa-briefcase" aria-hidden="true"></i>View Services</a>
*@
                             <a class="dropdown-item" href="@Url.Action("UpdateZipcodeAndCategories", "dashboard")"><i class="fa fa-gear" aria-hidden="true"></i>@Localizer["Change Zipcodes/Categories"]</a>

                            }
                        }
                        @if (Model.LoggedInUser.RoleId!=null)
                        {
                            if(Model.LoggedInUser.RoleId!=4)
                            {
                                <a class="dropdown-item" href="@Url.Action("ViewMembershipPlan", "dashboard")"   ><i class="fa fa-file" aria-hidden="true"></i>@Localizer["View Membership Plan"]</a>
                            }
                            else
                            {
                                <a class="dropdown-item" href="@Url.Action("ViewMembershipPlanHomeOwner", "dashboard")"   ><i class="fa fa-file" aria-hidden="true"></i>@Localizer["View Membership Plan"]</a>
                            }
                        }
<a class="dropdown-item" href="@Url.Action("Resetpassword","dashboard")"><i class="fa fa-key" aria-hidden="true"></i>@Localizer["Change Password"]</a>
                      
                     @*   <a class="dropdown-item" href="#"><i class="fa fa-key" aria-hidden="true"></i> Change Password</a>*@  

<a class="dropdown-item" href="@Url.Action("Logout", "dashboard")"> <i class="fa fa-power-off" aria-hidden="true"></i> @Localizer["Logout"]</a>
                    </div>
                </li>
                </ul>
                </div>



        

        </div>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <hr class="mb-1 border-top-0" />
            <ul class="navbar-nav  ml-auto">
                <li id="divmessage"></li>
                <li class="nav-item header-searchbar position-relative">

                   
                </li>
              
               
                <li class="nav-item dropdown user-profile-imge mobile-user-none">
                    <a class="nav-link text-dark dropdown-toggle d-flex align-items-center" href="#" id="navbardrop" data-toggle="dropdown">
                        @if(!string.IsNullOrEmpty(Model.LoggedInUser.ProfilePicture))
                        {
                             <img alt="logo"  class="IconBorder" src="../Uploads/@Model.LoggedInUser.ProfilePicture" width="38" /><span class="text-white">@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName </span>  
                        }
                        else
                        {
                             <img alt="logo" style="margin-right:5px;" style="margin-right:5px;" src="../images/DefaultProfile.png" class="IconBorder" width="38" /><span class="text-white">@Model.LoggedInUser.FirstName @Model.LoggedInUser.LastName</span>
                        }

                    </a>
                     <div class="dropdown-menu ">
                        <a class="dropdown-item" href="@Url.Action("UserProfileDetails", "dashboard")"  > <i class="fa fa-user" aria-hidden="true"></i>@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName</a>
                        
                        @if (Model.LoggedInUser.RoleId!=null)
                        {
                            if(Model.LoggedInUser.RoleId!=4)
                            {
                             <a class="dropdown-item" href="@Url.Action("businessprofiledetail", "dashboard")"><i class="fa fa-pencil" aria-hidden="true"></i>@Localizer["View Business Profile"]</a>
                          <a class="dropdown-item" href="@Url.Action("UpdateZipcodeAndCategories", "dashboard")"><i class="fa fa-gear" aria-hidden="true"></i>@Localizer["Change Zipcodes/Categories"]</a>

                            }
                        }
                        @if (Model.LoggedInUser.RoleId!=null)
                        {
                            if(Model.LoggedInUser.RoleId!=4)
                            {
                                <a class="dropdown-item" href="@Url.Action("ViewMembershipPlan", "dashboard")"   ><i class="fa fa-file" aria-hidden="true"></i>@Localizer["View Membership Plan"]</a>
                            }
                            else
                            {
                                <a class="dropdown-item" href="@Url.Action("ViewMembershipPlanHomeOwner", "dashboard")"   ><i class="fa fa-file" aria-hidden="true"></i>@Localizer["View Membership Plan"]</a>
                            }
                        }
@*                        <a class="dropdown-item" href="@Url.Action("ViewMembershipPlan", "dashboard")"   ><i class="fa fa-file" aria-hidden="true"></i>View Membership Plan</a>
*@                       


<a class="dropdown-item" href="@Url.Action("Resetpassword","dashboard")"><i class="fa fa-key" aria-hidden="true"></i> @Localizer["Change Password"]</a>
                      
                     @*   <a class="dropdown-item" href="#"><i class="fa fa-key" aria-hidden="true"></i> Change Password</a>*@  

<a class="dropdown-item" href="@Url.Action("Logout", "dashboard")"> <i class="fa fa-power-off" aria-hidden="true"></i> @Localizer["Logout"]</a>
                    </div>
                </li>
            </ul>
        </div>
    </nav>
    <div class="logo-loader">
        <div class="logo-loader-pulse pulse" id="Idloader"><img src="~/images/Kopke-brand-logo.png" /></div>
    </div>
   
    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>
 <div class="footer">
       <p class="footer-line m-0">@Localizer["&#169; Copyright 2023 Prohz. All rights reserved."]</p>
   </div>

    

   <script src="~/js/jquery.min.js"></script>
   <script src="https://code.jquery.com/ui/1.13.1/jquery-ui.js"></script>
   <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.11.1/jquery.validate.min.js"></script>
   <script src="~/js/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.min.js"></script>
    @* <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"></script>*@
       @* <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>*@
    @*<script src="~/js/ValidateForms.js"></script>*@

        <script src="~/js/bootstrap.bundle.min.js"></script>
       @* <script src="~/js/Localization.js"></script>*@
    <script src="~/js/Dashboard.js"></script>
    @*  <script src="~/js/Subscription.js"></script> *@
    <script type="text/javascript" src="~/js/jquery.dataTables.min.js"></script>
    <script src="~/js/jquery.dataTables.min1.js"></script>
    <script src="~/js/jquery.dataTables.min2.js"></script>
         <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.4.20/dist/sweetalert2.all.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
    @*     <script src="~/js/ValidateForms.js"></script>*@
    <script src="~/js/ValidateForms.js" asp-append-version="true"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
  




    <script>
var urlprefix = "";
    if (window.location.href.indexOf("KopkeHome-FMRS-QA") > -1) {
        urlprefix = '/KopkeHome-FMRS-QA';
    }

   

    </script>
   
</body>

</html>