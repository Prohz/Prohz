@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Dashboard</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.12.1/css/dataTables.bootstrap5.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font CSS -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link href='https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css' rel='stylesheet'>

    <!-- Custom CSS -->
    <link href="~/Admin/css/style.css" rel="stylesheet">
    <link href="~/Admin/css/responsive.css" rel="stylesheet">
</head>

<body>
      <div class="logo-loader">
        <div class="logo-loader-pulse pulse" id="Idloader"><img id="Logoimgurl" src="~/images/Kopke-brand-logo.png" /></div>
    </div>
    <div class="wrapper">
        <div class="leftPanel">
            <a class="closesidbar">&times;</a>
            <div class="sidebar">
                <div class="logo-content">
                    <a href="@Url.Action("Dashboard", "Admin")"><img style="height:45px;width: 159px !important;" src="~/images/Kopke-brand-logo.png" alt="" class="w-100 desktoplogo"></a>
                     <img src="~/images/minilogo.png" class="img-fluid desktoplogo2" />
                </div>


                <div class="sideMenu-container">

                        <ul class="sideMenu">
                            <li class="AdminLeftMenuList">
                                <a href="@Url.Action("dashboard","admin")">
                                    <i class='bx bx-home'></i>
                                    <span class="link-name">Dashboard</span>
                                </a>
                            </li>
                             <li class="AdminLeftMenuList">
                                <a href="@Url.Action("CustomMembershipPlanRequests","admin")">
                                    <i class='bx bx-grid-alt'></i>
                                    <span class="link-name">Custom Membership Requests</span>
                                </a>
                            </li>
                             <li class="AdminLeftMenuList">
                                <a href="@Url.Action("DocumentsVerification","admin")">
                                    <i class='bx bx-cog'></i>
                                    <span class="link-name">Documents Verification</span>
                                </a>
                            </li>
                              <li class="AdminLeftMenuList">
                                <a href="@Url.Action("faq","admin")">
                                    <i class='bx bx-file'></i>
                                    <span class="link-name">FAQ's</span>
                                </a>
                            </li>
                              <li class="AdminLeftMenuList">
                                <a href="@Url.Action("PromoVideos","admin")">
                                    <i class='bx bx-film'></i>
                                    <span class="link-name">Promo Video</span>
                                </a>
                            </li>

                             <li class="AdminLeftMenuList">
                                <a href="@Url.Action("categories","admin")">
                                    <i class='bx bx-basket'></i>
                                    <span class="link-name">Categories</span>
                                </a>
                            </li> 
                             <li class="AdminLeftMenuList">
                                <a href="@Url.Action("SalesAssociate","admin")">
                                    <i class='bx bxs-user-badge'></i>
                                    <span class="link-name">Sales Associate</span>
                                </a>
                            </li>

                             <li class="AdminLeftMenuList">
                                <a href="@Url.Action("ProhzLegalFiles","admin")">
                                    <i class='bx bxs-bank'></i>
                                    <span class="link-name">Prohz Legal Files</span>
                                </a>
                            </li>

                        </ul>

                </div>


            </div>
        </div>
        <div class="rightPanel">
            <header>

                <nav class="navbar navbar-expand-md">
                    <div class="container-fluid">
                        <div class="toggle-button">
                            <a href="#">
                                <span class="menu-btn"><i class='bx bx-menu' ></i></span>
                            </a>
                        </div>
                        <div class="d-flex">
                            <div class="user-profile">
                                        @{
                                            string profile = "Images/DefaultProfile.png";
                                            string CurrentUserName = string.Empty;
                                            if(!string.IsNullOrEmpty( HttpContextAccessor.HttpContext.Request.Cookies["CurrentUserProfilePic"]))
                                            {
                                                profile=HttpContextAccessor.HttpContext.Request.Cookies["CurrentUserProfilePic"];
                                            }
                                            if(!string.IsNullOrEmpty( HttpContextAccessor.HttpContext.Request.Cookies["CurrentUserName"]))
                                            {
                                                CurrentUserName=HttpContextAccessor.HttpContext.Request.Cookies["CurrentUserName"];
                                            }
                                        }
                                        <img src="~/Uploads/@profile" onerror="this.src='../images/DefaultProfile.png'" alt="" class="w-100">
                                    </div>
                                    <div class="dropdown ms-2">
                                    <a class="nav-link dropdown-toggle profile-toggle text-white h-100 d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">@CurrentUserName</a>
                                    <ul class="dropdown-menu">
                                        
                                        <li><a class="dropdown-item" href="@Url.Action("Logout", "dashboard")">Logout</a></li>
                                    </ul>
                                    </div>
                        </div>
                    </div>
                </nav>
            </header>

            <div class="home-content">
              

                @RenderBody()
            </div>
        </div>
    </div>
    <!-- ====Scripts=== -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/1.12.1/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.12.1/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.11.1/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.4.20/dist/sweetalert2.all.min.js"></script>
    <script src="~/Admin/js/Admin.js" ></script>
