@model KopkeHome_ModelLayer.ViewModels.DashboardViewModels.BaseViewModel

@inject IViewLocalizer Localizer
@{
    //Layout = "~/Views/Shared/_Dashboard.cshtml";
}
<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css">


    <link rel="stylesheet" href="~/KopkeHome_Web.styles.css" asp-append-version="true" />

    @*
        <link rel="stylesheet" type="text/css" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.6.3/css/font-awesome.min.css">*@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/master.css" asp-append-version="true" />
</head>
<body>
    <div class="registration-container black-bg">
        <div class="registration-container-branding d-flex justify-content-between align-items-center">
            <div class="kopkehome-logo">
               <a href="@Url.Action("SignIn","user")"> 
            <img src="~/images/Kopke-brand-logo.png" width="140" />
            </a>
            </div>

            <div class="rgstr-box-heading text-center">
                <h2 class="orange-clr"></h2>
                <p class="text-white m-0"></p>
            </div>

            <div class="">
                @{
                    if (Model.LoggedInUser != null)
                    {
                        <a class="nav-link text-dark dropdown-toggle d-flex align-items-center" href="#" id="navbardrop" data-toggle="dropdown">
                            @if (!string.IsNullOrEmpty(Model.LoggedInUser.ProfilePicture))
                            {
                                <img alt="logo" style="margin-right:11px; class="IconBorder" src="~/Uploads/@Model.LoggedInUser.ProfilePicture" width="38" />



                                <span class="text-white">@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName </span>

                            }
                            else
                            {
                                <img alt="logo" style="margin-right:11px;" src="~/images/DefaultProfile.png" class="IconBorder" width="38" />



                                <span class="text-white">@Model.LoggedInUser.FirstName @Model.LoggedInUser.LastName</span>
                            }

                        </a>
                    }
                    else
                    {
                        <a class="nav-link text-dark dropdown-toggle d-flex align-items-center">
                            <img alt="logo" style="margin-right:5px;" src="~/images/DefaultProfile.png" class="IconBorder" width="38" /><span class="ml-2 header-navbar-user-email">No user fOUND</span>
                        </a>
                    }

                }



            </div>

        </div>

        <div class="">

            <div class="row">
                <div class="col-md-12 col-lg-12 col-xl-12">
                  <div class="rgstr-box-heading text-center" style="width:100% !important">
                <h2 class="orange-clr">@Localizer["Your account is under verification."]</h2>
                <h3 class="text-white m-0">@Localizer["Most applications are approved in 1-2 business days. The time to be verified is related to the accuracy of the information provided by the applicant. Good, accurate information equates to faster verification."]</h3>
                <br></br>
                        <h3 class="orange-clr m-0">@Localizer["Please check back in 48 hours and look for a verification complete email from us to access your account."]</h3>
            </div>
                </div>

            </div>

            <font size="4">


          
              @*  <p class="text-danger text-center orange-clr"><a href="@Url.Action("index", "Home")" class="btn btn-info">@Localizer["Exit"]</a></p>*@

                
            </font>
        </div>
    </div>





    <script src="~/js/jquery.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.1/jquery-ui.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/additional-methods.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
    <script src="~/js/ValidateForms.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.4.20/dist/sweetalert2.all.min.js"></script>
    <script>
        var urlprefix = "";
            if (window.location.href.indexOf("KopkeHome-FMRS") > -1) {
                urlprefix = '/KopkeHome-FMRS';
            }



    </script>
  
</body>
</html>