@{
    Layout = "~/Views/Shared/_HomePageLayout.cshtml";
}


@inject IViewLocalizer Localizer
@inject IOptions<RequestLocalizationOptions> locOptions

 <link rel="stylesheet" href="~/css/vendor.min.css" asp-append-version="true" />
 <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />

<div class="container mainbodysec">
   <div class="card" >
  <div class="card-body">
    <h5 class="card-title">@Localizer["Contact Us"]</h5>
    <h6 class="card-subtitle mb-2 text-muted"></h6>
    <p class="card-text ">@Localizer["As we grow we appreciate your feedback"]</p>

            <style>
                /* Apply some basic styling to the form container */
                form {
                    max-width: 900px; /* Set a maximum width to prevent the form from becoming too wide */
                    margin: 0 auto; /* Center the form on the page */
                }

                /* Apply styles to the form elements */
                label {
                    display: block; /* Make labels block-level for better spacing */
                    margin-bottom: 5px; /* Add some space below the labels */
                }

                input,
                textarea, select {
                    width: 100%; /* Make input and textarea elements fill the container */
                    box-sizing: border-box; /* Include padding and border in the element's total width */
                    margin: 20px; /* Add some space below each input and textarea */
                    padding: 8px; /* Add padding for better appearance */
                }

                button {
                    padding: 10px; /* Add padding to the button for better appearance */
                }
            </style>

            <form method="post" asp-controller="Home" asp-action="CallSendEmailToProhz">
                <div>
                    <label for="fromEmail">Your Email:</label>
                    <input type="email" name="FromEmail" required>
                </div>
                <label for="Reason">How can we help?</label>
                <select name="Reason" required>
                    
                    <option value="">What can we help with?</option>
                    <option value="Feedback">I want to provide feedback</option>
                    <option value="Password Assistance">I need help with my password/login</option>
                </select>

                <div>
                    <label for="message">Message:</label>
                    <textarea name="Message" rows="4" required></textarea>
                </div>

                <div>
                    <button type="submit">Send Email</button>
                </div>
            </form>



    <a href="@Url.Action("HowDoesItWork","Home")" class="card-link">@Localizer["Learn More"]</a>
    <a href="@Url.Action("SignUp","User")" class="card-link">@Localizer["Join Prohz"]</a>
  </div>
   
  <script src="~/js/vendor.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
   
</div>
</div>
