    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/additional-methods.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
    <script src="~/js/ValidateForms.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.4.20/dist/sweetalert2.all.min.js"></script>
    <script>
        var urlprefix = "";
            if (window.location.href.indexOf("KopkeHome-FMRS") > -1) {
                urlprefix = '/KopkeHome-FMRS';
            }



    </script>
    <script>


            function SilverRadio()
         {
             $("#CSTMLOADER").show();
             var selectedVal = "";
        var selected = $("input[type='radio'][name='SilverPrice']:checked");
        console.log(selected.val());
         if (selected.length > 0)
         {

             selectedVal = selected.val();
              var dataId=selected.attr("data-id")
             $.ajax({
             type: 'Get',
             url: urlprefix+'/Membership/PaymentCard?priceId='+selectedVal+'&planId='+dataId,


             success: function (res)
             {

                if(res==1)
                {

                    window.location = urlprefix+"/Membership/Payment/";
                }
                else
                {$("#CSTMLOADER").hide();
                    alert("Something went wrong.");
                }


             }


                 });
         }
         else{
             $("#CSTMLOADER").hide();
            Swal.fire('Please select type of plan.(Quaterly/Annually)')
         }


         }


            function GoldRadio()
         {$("#CSTMLOADER").show();
           var selectedVal = "";
        var selected = $("input[type='radio'][name='GoldPrice']:checked");
        console.log(selected.val());
         if (selected.length > 0)
         {

             selectedVal = selected.val();

             var dataId=selected.attr("data-id")
             $.ajax({
             type: 'Get',
             url: urlprefix+'/Membership/PaymentCard?priceId='+selectedVal+'&planId='+dataId,


             success: function (res)
             {

                if(res==1)
                {

                    window.location = urlprefix+"/Membership/Payment/";
                }
                else
                {
                    $("#CSTMLOADER").hide();
                    alert("Something went wrong.");
                }


             }


                 });
         }
         else{
             $("#CSTMLOADER").hide();
             Swal.fire('Please select type of plan.(Quaterly/Annually)')
         }

         }





         
        function showDatasilverH() {
            var dataDiv = document.getElementById("showsilver90H");
            dataDiv.style.display = "none";
            var dataDiv2 = document.getElementById("showsilver365H");
            dataDiv2.style.display = "block";

        }

        function hideDatasilverH() {
            var dataDiv = document.getElementById("showsilver365H");
            dataDiv.style.display = "none";
            var dataDiv2 = document.getElementById("showsilver90H");
            dataDiv2.style.display = "block";
            dataDiv2.style.visibility = 'visible'
            $('#showsilver90H').removeAttr('hidden');
        }


        function showDatagoldH() {
            var dataDiv = document.getElementById("showgold90H");
            dataDiv.style.display = "none";
            var dataDiv2 = document.getElementById("showgold365H");
            dataDiv2.style.display = "block";

        }

        function hideDatagoldH() {
            var dataDiv = document.getElementById("showgold365H");
            dataDiv.style.display = "none";
            var dataDiv2 = document.getElementById("showgold90H");
            dataDiv2.style.display = "block";
            dataDiv2.style.visibility = 'visible'
            $('#showgold90H').removeAttr('hidden');
        }
    </script>

</body>
</html>

