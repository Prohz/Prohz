@model KopkeHome_ModelLayer.ViewModels.PaymentModels.PaymentSuccessViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Payment Success"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="registration-container black-bg">

    <div class="registration-container-branding d-flex justify-content-between align-items-center">
            <div class="kopkehome-logo">
                <img src="~/images/Kopke-brand-logo.png" width="140" />
            </div>

            <div class="rgstr-box-heading text-center">
                <h2 class="orange-clr"></h2>
       
            </div>

              <div class="">
            @{
                if (Model.LoggedInUser != null)
                {
                     <a class="nav-link text-dark dropdown-toggle d-flex align-items-center" href="#" id="navbardrop" data-toggle="dropdown">
                        @if(!string.IsNullOrEmpty(Model.LoggedInUser.ProfilePicture))
                        {
                             <img alt="logo" style="margin-right:11px;  class="IconBorder" src="~/Uploads/@Model.LoggedInUser.ProfilePicture" width="38" /><span class="text-white">@Model.LoggedInUser.FirstName  @Model.LoggedInUser.LastName </span>  
                        }
                        else
                        {
                             <img alt="logo" style="margin-right:11px;" src="~/images/DefaultProfile.png" class="IconBorder" width="38" /><span class="text-white">@Model.LoggedInUser.FirstName @Model.LoggedInUser.LastName</span>
                        }

                    </a>
                }

             
                    }
     
                </div>

                

     
  
 
  



</div> 





<div class="modal p-0 fade email-sent-success-modal" style="display:contents !important">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
      

        <div class="modal-body">
          <div class="text-center email-sent-success-main-heading">         
               <img width="175px" src="~/images/success-gif1.gif" />
               @*<img width="175px" src="~/images/success-gif.gif" />*@
          
              <h3 class="text-white">@Localizer["Payment Success"]</h3>
               <p>@Localizer["We have recieved your payment.Now You can download your Invoice."]</p>        
          </div>
          
         <div class="verify-email text-center mb-2">
         

           <a class="btn green-email-verify-btn" href="@Model.DocUrl"> 
         @Localizer["Download Invoice"] <i class="fa fa-download"></i></a>
          <a class="btn green-email-verify-btn" href="@Url.Action("selectzipcodesandcategories", "Membership")"> 
           @Localizer["Continue"] <i class="fa fa-long-arrow-right"></i></a>

           @* <a class="btn green-email-verify-btn" href="#"> 
           Continue <i class="fa fa-long-arrow-right"></i></a>*@
       </div>
        
     
        
        </div>
        
      </div>
    </div>
  </div>




</div>  


