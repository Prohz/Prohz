            var ProhzGreyLogo = '<img style="height: 90px;" src="' + urlprefix + "'"

        </script>
        <script>



            var silver_PricePerYear = @Model.priceYearlySilver;

            // Check if silver_PricePerYear is equal to zero
            if (silver_PricePerYear === 0) {
                document.addEventListener("DOMContentLoaded", function () {
                    // Find and update the "Best Value" to "Referral Added"
                    var bestValueElement = document.querySelector('.card-wrapper.best-value .best');
                    if (bestValueElement) {
                        bestValueElement.textContent = 'Referral Added';
                    }

                    // Update the disclaimer text to "Free with Referral"
                    var disclaimerElement = document.querySelector('.card-wrapper.best-value p.disclaimer');
                    if (disclaimerElement) {
                        disclaimerElement.textContent = 'Free with Referral';
                    }
                });
            }
            



            function AsubmitCustomPlanRequest(form) {

                if ($(form).valid()) {
                    $.ajax({
                        type: 'POST',
                        url: urlprefix + '/Membership/SaveCustomZipcodesRequest',
                        data: $(form).serialize(),

                        success: function (res) {

                            if (res == "1") {
                                $('#exampleModal').modal('hide');
                                $('#exampleModal2').modal('show');
                            } else {
                                Swal.fire({
                                    title: localizer('You have already requested for custom memebrship plan', 'Ya ha solicitado un plan de membresía personalizado', $('#ProhzLangDDL option:selected').val()),
                                    iconHtml: ProhzGreyLogo,
                                    text: localizer('Once your custom membership plan is created it will be visible to you in this page with other plans.', 'Una vez que se haya creado su plan de membresía personalizado, podrá verlo en esta página con otros planes.', $('#ProhzLangDDL option:selected').val()),

                                })
                            }

                        }
                    });
                }

                return false;
            }
            function CustomRadio() {
                $("#CSTMLOADER").show();
                //var ele = document.getElementsByName('BronzePrice');

                var selectedVal = "";
                var selected = $("input[type='radio'][name='CustomPrice']:checked");
                if (selected.length > 0) {

                    selectedVal = selected.val();
                    var dataId = selected.attr("data-id");
                    var userid = selected.attr("data-userid");
                    $.ajax({
                        type: 'Get',
                        url: urlprefix + '/Membership/PaymentForCustomPlan?priceId=' + selectedVal + '&planId=' + dataId + '&userid=' + userid,

                        success: function (res) {

                            if (res == 1) {

                                window.location = urlprefix + "/Membership/CustomPlanGateway/";
                            }
                            else {
                                $("#CSTMLOADER").hide();
                                alert("Something went wrong.");
                            }


                        }


                    });
                }
                else {
                    $("#CSTMLOADER").hide();

                    Swal.fire(localizer('Please select type of plan.(Quarterly/Annually)', 'Seleccione el tipo de plan. (Trimestral/Anual)', $('#ProhzLangDDL option:selected').val()))

                }




            }


            function BronzeRadio() {
                $("#CSTMLOADER").show();
                //var ele = document.getElementsByName('BronzePrice');


                // Swapped out the dynamic value for static value.  Original value was `selected.val();`
                priceId = "@Model.PriceYearlyBronzeID";
                var dataId = @PlanIdBronze;
                console.log(priceId)
                $.ajax({
                    type: 'Get',
                    url: urlprefix + '/Membership/PaymentCard?priceId=' + priceId + '&planId=' + dataId,

                    success: function (res) {

                        if (res == 1) {

                            window.location = urlprefix + "/Membership/Payment/";
                        }
                        else {
                            $("#CSTMLOADER").hide();
                            alert("Something went wrong.");
                        }


                    }


                });




            }

            function SilverRadio() {
                $("#CSTMLOADER").show();


                priceId = "@Model.PriceYearlySilverID";
                var dataId = @PlanIdSilver;
                $.ajax({
                    type: 'Get',
                    url: urlprefix + '/Membership/PaymentCard?priceId=' + priceId + '&planId=' + dataId,
                    success: function (res) {

                        if (res == 1) {
