            }

            $(function () {

                $("form[name='submitCustomPlanRequest']").validate({

                    rules: {
                        NumberOfZipcodes: {
                            required: true,

                        },
                        Descrption: "required",
                        // WebApp:"required",
                        NumberOfcategories: {
                            required: true,

                        },


                    },
                    // Specify validation error messages
                    messages: {
                        NumberOfZipcodes: localizer('Please Enter Number Of Zip Codes.', 'Ingrese el número de códigos postales.', $('#ProhzLangDDL option:selected').val()),
                        NumberOfcategories: localizer('Please Enter Number Of categories.', 'Ingrese el número de categorías.', $('#ProhzLangDDL option:selected').val()),
                        // WebApp:"Please choose one.",
                        Descrption: localizer('Please enter Descrption.', 'Ingrese la descripción.', $('#ProhzLangDDL option:selected').val())
                    },

