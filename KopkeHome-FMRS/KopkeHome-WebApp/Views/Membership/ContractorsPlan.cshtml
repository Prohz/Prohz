                        }
                        else {
                            $("#CSTMLOADER").hide();
                            alert("Something went wrong.");
                        }


                    }


                });




            }


            function GoldRadio() {
                $("#CSTMLOADER").show();


                priceId = "@Model.PriceYearlyGoldID";
                var dataId = @PlanIdGold;
                $.ajax({
                    type: 'Get',
                    url: urlprefix + '/Membership/PaymentCard?priceId=' + priceId + '&planId=' + dataId,


                    success: function (res) {

                        if (res == 1) {

