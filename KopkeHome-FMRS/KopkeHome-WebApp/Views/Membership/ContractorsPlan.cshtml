                Gold_IsPhoneApp = "fa-check";
            }
            else
            {
                Gold_IsPhoneApp = "fa-times";
            }

            // bool Gold_IsWeb = Gold.Website;
            //  bool Gold_IsPhoneApp = Gold.PhoneApp;
            string membertype = string.Empty;

            if (Model.LoggedInUser.RoleId == 2)
            {
                membertype = Localizer["Sub Contractor"].Value;
            }
            else if (Model.LoggedInUser.RoleId == 3)
            {
                membertype = Localizer["Independent Contractor"].Value;
            }
            else
            {
                membertype = Localizer["Contractor"].Value;
            }

