        @{
            double percentbr = 0;
            var bronze = Model.Plans.Where(x => x.Title.Contains("Bronze")).FirstOrDefault();
            int PlanIdBronze = bronze.Id;
            double bronzeprice_PricePerMonth = bronze.PricePerMonth;
            string bronze_Categories = bronze.Categories;
            string bronze_ZipCodes = bronze.ZipCodes;
            double bronze_PricePerYear = bronze.PricePerYear;
            string bronze_IsWeb = string.Empty;
            string bronze_IsPhoneApp = string.Empty;


            var discount = ((bronzeprice_PricePerMonth * 4) - bronze_PricePerYear);
            percentbr = (discount / (bronzeprice_PricePerMonth * 4)) * 100;


            if (bronze.Website)
            {
                bronze_IsWeb = "fa-check";
            }
            else
            {
                bronze_IsWeb = "fa-times";
            }
            if (bronze.PhoneApp)
            {
                bronze_IsPhoneApp = "fa-check";
            }
            else
            {
                bronze_IsPhoneApp = "fa-times";
            }


            double percentsl = 0;
            var silver = Model.Plans.Where(x => x.Title.Contains("Silver")).FirstOrDefault();
            int PlanIdSilver = silver.Id;
            double silver_PricePerMonth = Model.priceYearlySilver;
            string silver_Categories = silver.Categories;
            string silver_ZipCodes = silver.ZipCodes;
            double silver_PricePerYear = Model.priceYearlySilver;
            string silver_IsWeb = string.Empty;
            string silver_IsPhoneApp = string.Empty;
            var discountsl = ((silver_PricePerMonth * 4) - silver_PricePerYear);
            percentsl = (discountsl / (silver_PricePerMonth * 4)) * 100;
            if (silver.Website)
            {
                silver_IsWeb = "fa-check";
            }
            else
            {
                silver_IsWeb = "fa-times";
            }
            if (silver.PhoneApp)
            {
                silver_IsPhoneApp = "fa-check";
            }
            else
            {
                silver_IsPhoneApp = "fa-times";
            }

            double percentgl = 0;
            var Gold = Model.Plans.Where(x => x.Title.Contains("Gold")).FirstOrDefault();
            int PlanIdGold = Gold.Id;
            double Gold_PricePerMonth = Gold.PricePerMonth;
            string Gold_Categories = Gold.Categories;
            string Gold_ZipCodes = Gold.ZipCodes;
            double Gold_PricePerYear = Gold.PricePerYear;
            string Gold_IsWeb = string.Empty;
            string Gold_IsPhoneApp = string.Empty;
            var discountgl = ((Gold_PricePerMonth * 4) - Gold_PricePerYear);
            percentgl = (discountgl / (Gold_PricePerMonth * 4)) * 100;
            if (Gold.Website)
            {
                Gold_IsWeb = "fa-check";
            }
            else
            {
                Gold_IsWeb = "fa-times";
            }
            if (Gold.PhoneApp)
