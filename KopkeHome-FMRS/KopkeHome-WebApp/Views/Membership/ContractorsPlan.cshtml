        <!--  custom plan Modal -->
        <div class="modal p-0 fade contactorModal-email-varification" data-keyboard="false" data-backdrop="static" id="exampleModal">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title">@Localizer["Custom Plan"]</h4>
                        <button type="button" class="close modal-cstm-close" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <div class="text-center email-varification-main-heading">
                            <h3 class="text-white">@Localizer["Enter Plan details"]</h3>
                            <p>@Localizer["Please describe your requirements in detail."]</p>
                        </div>
                        <form enctype="multipart/form-data" name="submitCustomPlanRequest" method="post" onsubmit="return AsubmitCustomPlanRequest(this);">

                            <input name="UserId" type="hidden" value="@Model.LoggedInUser.Id" />


                            <div class=" rgstr-input-form-box">
                                <label for="Descrption">@Localizer["Requirement Details"] :</label>
<textarea name="Descrption" class="form-control input-sm TextUpperLower" placeholder="" rows="3"></textarea>
                                <span for="Descrption" id="Descrption-error" class="text-danger error"></span>
                            </div>
                            <div class="verify-email text-center mb-2">
                                <button type="submit" class="btn green-email-verify-btn">@Localizer["Send"]</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
