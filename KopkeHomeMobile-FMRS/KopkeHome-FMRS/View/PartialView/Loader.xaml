<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KopkeHome_FMRS.View.PartialView.Loader">
    <ContentView.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" BackgroundColor="Black" Opacity="0.3"/>
            <Grid Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Center">
                <ActivityIndicator IsEnabled="True" IsVisible="True" IsRunning="True" Color="#add136"/>
            </Grid>
        </Grid>
    </ContentView.Content>
</ContentView>


